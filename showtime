#!/bin/bash

# 定义颜色以便区分表头
BLUE='\033[0;34m'
NC='\033[0m' # 无颜色

echo -e "${BLUE}------------------------------------------------------------------------------------------------${NC}"
printf "%-35s | %-30s | %-s\n" "命令 (Command)" "执行结果 (Result)" "说明 (Description)"
echo -e "${BLUE}------------------------------------------------------------------------------------------------${NC}"

# 1. 基础输出
printf "%-35s | %-30s | %-s\n" "date" "$(date)" "默认系统日期时间格式"
printf "%-35s | %-30s | %-s\n" "date +\"%Y-%m-%d\"" "$(date +"%Y-%m-%d")" "标准日期 (YYYY-MM-DD)"
printf "%-35s | %-30s | %-s\n" "date +\"%H:%M:%S\"" "$(date +"%H:%M:%S")" "标准时间 (HH:MM:SS)"


# 2. 格式化与精度
printf "%-35s | %-30s | %-s\n" "date +\"%Y%m%d_%H%M%S\"" "$(date +"%Y%m%d_%H%M%S")" "紧凑格式 (常用于文件名)"
printf "%-35s | %-30s | %-s\n" "date +\"%F %T\"" "$(date +"%F %T")" "%F-%T 快速简写组合"
printf "%-35s | %-30s | %-s\n" "date +\"%...%3N\"" "$(date +"%Y-%m-%d %H:%M:%S.%3N")" "带毫秒的时间戳"
printf "%-35s | %-30s | %-s\n" "date +\"%...%N\"" "$(date +"%Y-%m-%d %H:%M:%S.%N")" "带纳秒的时间戳"
printf "%-35s | %-30s | %-s\n" "date +%N" "$(date +%N)" "当前秒内的纳秒偏移量"
printf "%-35s | %-30s | %-s\n" "date +\"%s\"" "$(date +"%s")" "Unix 时间戳 (秒)"
printf "%-35s | %-30s | %-s\n" "date +\"%s%3N\"" "$(date +%s%3N)" "13位 Unix 毫秒戳 (ms)"
printf "%-35s | %-30s | %-s\n" "date +\"%s%6N\"" "$(date +%s%6N)" "16位 Unix 微秒戳 (μs)"
printf "%-35s | %-30s | %-s\n" "date +%s%N" "$(date +%s%N)" "19位 Unix 纳秒戳 (ns)"

# 3. 时区
printf "%-35s | %-30s | %-s\n" "date +\"%Z %z\"" "$(date +"%Z %z")" "显示时区缩写及偏移量"

# 4. 日期计算
printf "%-35s | %-30s | %-s\n" "date -d \"yesterday\" +\"%F\"" "$(date --date "yesterday" +"%F")" "获取昨天的日期"
printf "%-35s | %-30s | %-s\n" "date -d \"tomorrow\" +\"%F\"" "$(date --date "tomorrow" +"%F")" "获取明天的日期"
printf "%-35s | %-30s | %-s\n" "date -d \"next Monday\" +\"%F\"" "$(date --date "next Monday" +"%F")" "获取下周一的日期"

echo -e "${BLUE}------------------------------------------------------------------------------------------------${NC}"

