#!/usr/bin/env bash

proxy="${proxy:-}"
noproxy="${noproxy:-}"
out="${out:-}"
url="${url:-}"
HELP="${HELP:-}"

# 暂存非选项参数的数组
positional_args=()

while [ $# -gt 0 ]; do
    case "$1" in
        --proxy|-x)
            proxy="$2"; shift 2 ;;
        --noproxy|--no-proxy)
            noproxy="$2"; shift 2 ;;
        --out|-o)
            out="$2"; shift 2 ;;
        --help|-h)
            HELP=1; shift ;;
        --url|-fSL|"-f#SL") # 兼容你原来的显性参数
            url="$2"; shift 2 ;;
        --*)
            echo "Illegal option $1"; shift ;;
        -*)
            # 处理可能的合并短参数或其他未知短参数
            echo "Unknown option $1"; shift ;;
        *)
            # 【核心逻辑】如果不以 - 开头，则视为位置参数（URL）
            positional_args+=("$1")
            shift
            ;;
    esac
done

# 如果 url 变量仍然为空，则从位置参数中提取第一个
if [ -z "${url}" ] && [ ${#positional_args[@]} -gt 0 ]; then
    url="${positional_args[0]}"
fi

# 帮助信息
if [ "$HELP" = "1" ] || [ -z "${url}" ]; then
    echo "Usage: dl [options] <url>"
    echo "--proxy|-x            proxy"
    echo "--noproxy             noproxy"
    echo "--out|-o              outputfile"
    echo "--url                 explicit url"
    echo "Example:"
    echo "  dl https://example.com/file.img"
    echo "  dl -o test.img https://example.com/file.img"
    echo "  dl --proxy http://127.0.0.1:7890 https://example.com/file.img"
    exit 0
fi

# 组装 aria2c 参数
aria2c_opts_array=()
[ -n "${proxy}" ] && aria2c_opts_array+=("--all-proxy=${proxy}")
[ -n "${noproxy}" ] && aria2c_opts_array+=("--no-proxy=${noproxy}")
[ -n "${out}" ] && aria2c_opts_array+=("-o" "${out}")
# aria2c -h#all |grep proxy
set -x
aria2c "${aria2c_opts_array[@]}" \
    --split=32 \
    --max-concurrent-downloads=32 \
    --max-connection-per-server=16 \
    --user-agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36" \
    --header="Referer: https://www.google.com/" \
    "${url}"