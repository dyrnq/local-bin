#!/bin/bash

# 定义颜色
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # 重置颜色

echo -e "${CYAN}====================================================================================================================${NC}"
printf "${YELLOW}%-55s | %-15s | %-s${NC}\n" "socat 命令示例 (Command Showcase)" "模式 (Mode)" "核心用途/说明 (Description)"
echo -e "${CYAN}====================================================================================================================${NC}"

# 1. 基础转发
printf "%-55s | %-15s | %-s\n" \
"socat TCP-L:8080,reuseaddr TCP:192.168.1.10:80" "单次转发" "最简单的点对点转发，处理完一个连接后退出"

# 2. 多并发转发 (你的常用命令)
printf "%-55s | %-15s | %-s\n" \
"socat TCP-L:9082,reuseaddr,fork TCP:192.168.9.219:5000" "并发中转" "使用 fork 为每个连接开启子进程，支持多人同时访问"

# 3. 流量黑洞
printf "%-55s | %-15s | %-s\n" \
"socat TCP-L:9082,reuseaddr,fork /dev/null" "性能测试" "只接收不处理，直接丢弃数据，常用于测试带宽或占位"

# 4. 本地文件读写
printf "%-55s | %-15s | %-s\n" \
"socat - TCP:192.168.9.219:5000" "交互测试" "将标准输入(-)连至远程端口，像 telnet 一样手动发包"

# 5. UDP 监听
printf "%-55s | %-15s | %-s\n" \
"socat UDP-L:123,reuseaddr,fork stdout" "协议嗅探" "监听 UDP 123 (NTP)，并将接收到的原始数据打印到屏幕"

# 6. 反弹 Shell (危险操作)
printf "%-55s | %-15s | %-s\n" \
"socat TCP-L:4444,reuseaddr,fork EXEC:/bin/bash" "远程控制" "将监听端口直接绑定到本地 Bash，连上来就能执行命令"

# 7. 文件传输
printf "%-55s | %-15s | %-s\n" \
"socat TCP-L:2000,reuseaddr!!OPEN:test.txt,create" "文件接收" "监听端口，并将收到的所有数据写入 test.txt 文件"

echo -e "${CYAN}====================================================================================================================${NC}"
echo -e "${GREEN}提示: 'TCP-L' 是 'TCP-LISTEN' 的简写; 'TCP' 是 'TCP-CONNECT' 的简写。${NC}"